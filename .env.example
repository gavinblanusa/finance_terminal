# Database (required for portfolio, taxes, and optional market-data persistence)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gavin_financial
DB_USER=postgres
DB_PASSWORD=

# Optional: FRED (St. Louis Fed) — Treasury / Fed funds snapshot on Dashboard macro strip
# FRED_API_KEY=

# Optional: FastAPI read-only terminal (uvicorn terminal_api:app). When set, require Authorization: Bearer <key>
# GFT_API_KEY=
# GFT_CORS_ORIGINS=*                    # or http://localhost:3000,https://...
# GFT_RATE_LIMIT=60/minute              # or 0 / off / none to effectively disable

# Optional: market data APIs (app works with none; more keys = better coverage)
# ALPHA_VANTAGE_API_KEY=
# FMP_API_KEY=
# FINNHUB_API_KEY=
# MASSIVE_API_KEY=
# POLYGON_API_KEY=
# TWELVEDATA_API_KEY=
# EODHD_API_KEY=
# USE_OPENBB=true
# OPENBB_REQUEST_TIMEOUT_SEC=30
# USE_FINANCETOOLKIT=true

# Optional: local market-data-warehouse OHLCV (github.com/joemccann/market-data-warehouse), before OpenBB/yfinance
# GFT_MARKET_WAREHOUSE_BRONZE=/path/to/market-warehouse/data-lake/bronze
# GFT_MARKET_WAREHOUSE_DUCKDB=/path/to/market-warehouse/duckdb/market.duckdb
# GFT_MARKET_WAREHOUSE_TIMEOUT_SEC=5
